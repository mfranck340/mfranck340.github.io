---
import SideBarFooter from "./SideBarFooter.astro";
import { Image } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
const { sideBarActiveItemID } = Astro.props;

const BASE = import.meta.env.BASE_URL;
---

<div class="drawer-side z-40">
  <label for="my-drawer" class="drawer-overlay"></label>

  <aside class="sidebar-stars px-2 pt-2 h-auto min-h-full w-[19rem] bg-base-200 text-base-content flex flex-col relative overflow-hidden">
    <!-- overlay de estrellas -->
    <div class="stars-overlay"></div>

    <div class="w-fit mx-auto mt-5 mb-6 relative z-10">
      <a href={BASE}>
        <div class="avatar transition ease-in-out hover:scale-[102%] block m-auto">
          <div class="w-[8.5rem]">
            <Image class="mask mask-circle" format="webp" width={300} height={300} src="/mfranck340.github.io/profile.webp" alt="Profile image" />
          </div>
        </div>
      </a>
    </div>
    <SideBarMenu sideBarActiveItemID={sideBarActiveItemID} />
    <SideBarFooter />
  </aside>
</div>





<style>
  /* Contenedor (tu aside) */
  .sidebar-stars {
    position: relative;
    overflow: hidden;
  }

  /* Capa de estrellas encima del fondo, debajo del contenido */
  .stars-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;

    /* Varias “estrellas” con radial-gradients en posiciones diferentes */
    background:
      radial-gradient(circle at 12% 18%, rgba(255,255,255,.9) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 78% 22%, rgba(255,255,255,.8) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 34% 48%, rgba(255,255,255,.7) 0 1.2px, rgba(255,255,255,0) 2.4px),
      radial-gradient(circle at 88% 55%, rgba(255,255,255,.85) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 20% 72%, rgba(255,255,255,.75) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 60% 80%, rgba(255,255,255,.65) 0 1.2px, rgba(255,255,255,0) 2.5px),
      radial-gradient(circle at 45% 15%, rgba(255,255,255,.6) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 8%  90%, rgba(255,255,255,.8) 0 1.1px, rgba(255,255,255,0) 2.3px);

    /* Un pelín de glow general */
    filter: drop-shadow(0 0 6px rgba(255,255,255,.25));
    opacity: .55;

    /* Animación base: “respira”/titila */
    animation: starsTwinkle 3.6s ease-in-out infinite;
  }

  /* Segunda capa (más puntitos + timing distinto) usando ::before */
  .stars-overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 25% 30%, rgba(255,255,255,.55) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 52% 42%, rgba(255,255,255,.5) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 70% 70%, rgba(255,255,255,.6) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 90% 10%, rgba(255,255,255,.5) 0 1px, rgba(255,255,255,0) 2px),
      radial-gradient(circle at 10% 52%, rgba(255,255,255,.45) 0 1px, rgba(255,255,255,0) 2px);

    opacity: .4;
    filter: blur(.15px);
    animation: starsTwinkleAlt 2.9s ease-in-out infinite;
  }

  /* Tercera capa (alguna estrella “grande” que brilla fuerte) */
  .stars-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 40% 62%, rgba(255,255,255,1) 0 1.6px, rgba(255,255,255,0) 5px),
      radial-gradient(circle at 82% 38%, rgba(255,255,255,1) 0 1.8px, rgba(255,255,255,0) 6px);
    opacity: .0;
    filter: blur(.2px) drop-shadow(0 0 10px rgba(255,255,255,.35));
    animation: bigStarsPulse 4.8s ease-in-out infinite;
  }

  @keyframes starsTwinkle {
    0%, 100% { opacity: .35; filter: drop-shadow(0 0 4px rgba(255,255,255,.18)); }
    50%      { opacity: .75; filter: drop-shadow(0 0 10px rgba(255,255,255,.35)); }
  }

  @keyframes starsTwinkleAlt {
    0%, 100% { opacity: .2; transform: translateY(0); }
    50%      { opacity: .55; transform: translateY(-1px); }
  }

  @keyframes bigStarsPulse {
    0%, 35%, 100% { opacity: 0; }
    50%           { opacity: .55; }
    65%           { opacity: .15; }
  }

  /* Respeta usuarios con reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .stars-overlay,
    .stars-overlay::before,
    .stars-overlay::after {
      animation: none !important;
      opacity: .35;
    }
  }
</style>